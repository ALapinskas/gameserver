{
  "name": "@lapinskas/gameserver",
  "version": "2.1.4",
  "description": "Nodejs server for multiuser usage. Allows to create independent sessions.",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start-https": "CERT='/var/certs/cert.crt' KEY='/var/certs/cert.key' npm start",
    "i-prod": "npm install --omit=dev",
    "test": "mocha test/test.js",
    "start-https-val": "CERT='/var/certs/cert.crt' KEY='/var/certs/cert.key' VALIDATION='test_public.pem' npm start",
    "start-https-val-ps": "$env:VALIDATION='./test_public.pem'; node index.js",
    "gen_private_key": "openssl genpkey -algorithm ed25519 -out test_private.pem",
    "gen-public_key": "openssl pkey -in test_private.pem -pubout -out test_public.pem",
    "test-auth": "mocha test/auth.test.js"
  },
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ALapinskas/gameserver.git"
  },
  "publishConfig": {

  },
  "keywords": [
    "signaling",
    "games",
    "multiplayer",
    "videocalls",
    "chat",
    "server",
    "nodejs",
    "webserver",
    "websocket"
  ],
  "files": [
      "index.js",
      "node_modules",
      "README.md"
  ],
  "author": "Arturas-Alfredas Lapinskas",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/ALapinskas/gameserver/issues"
  },
  "homepage": "https://github.com/ALapinskas/gameserver#readme",
  "dependencies": {
    "ws":"^8.21.0"
  },
  "devDependencies": {
    "mocha": "10.0.0"
  }
}
